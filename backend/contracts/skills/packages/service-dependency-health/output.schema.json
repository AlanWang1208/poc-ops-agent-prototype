{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/skills/service-dependency-health-read/1.0.0/output.schema.json",
  "title": "service-dependency-health-read 输出",
  "description": "服务依赖健康检查的结构化输出。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "serviceName",
    "status",
    "dependencies",
    "checkedAt"
  ],
  "properties": {
    "serviceName": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "HEALTHY",
        "DEGRADED",
        "UNHEALTHY",
        "UNKNOWN"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "target",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "HEALTHY",
              "DEGRADED",
              "UNHEALTHY",
              "UNKNOWN"
            ]
          },
          "latencyMillis": {
            "type": "integer",
            "minimum": 0
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "checkedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
