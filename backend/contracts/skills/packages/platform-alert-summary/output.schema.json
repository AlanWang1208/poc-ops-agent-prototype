{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/skills/platform-alert-summary-read/1.0.0/output.schema.json",
  "title": "platform-alert-summary-read 输出",
  "description": "平台活跃告警摘要的结构化输出。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "minimumSeverity",
    "activeCount",
    "groups",
    "alerts",
    "generatedAt"
  ],
  "properties": {
    "minimumSeverity": {
      "type": "string",
      "enum": [
        "INFO",
        "WARNING",
        "CRITICAL"
      ]
    },
    "activeCount": {
      "type": "integer",
      "minimum": 0
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "count"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "INFO",
              "WARNING",
              "CRITICAL"
            ]
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "alertId",
          "severity",
          "summary"
        ],
        "properties": {
          "alertId": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "INFO",
              "WARNING",
              "CRITICAL"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
