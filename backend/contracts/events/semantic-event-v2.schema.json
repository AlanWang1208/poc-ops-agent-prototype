{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/events/semantic-event-v2.schema.json",
  "title": "Semantic event v2",
  "description": "操作台消费的携带 Team Workspace 上下文的 P1 强类型语义事件，不包含模型内部推理。",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "workspaceId", "eventId", "workflowId", "sequence", "timestamp", "type", "payload"],
  "properties": {
    "contractVersion": { "const": "2.0" },
    "workspaceId": { "type": "string", "minLength": 1 },
    "eventId": { "type": "string", "format": "uuid" },
    "workflowId": { "type": "string", "format": "uuid" },
    "sequence": { "type": "integer", "minimum": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "type": {
      "type": "string",
      "enum": [
        "WORKFLOW_STARTED",
        "SKILL_ROUTED",
        "WORKER_ACCEPTED",
        "WORKFLOW_COMPLETED",
        "WORKFLOW_FAILED"
      ]
    },
    "payload": {
      "oneOf": [
        { "$ref": "semantic-event-v1.schema.json#/$defs/workflowStartedPayload" },
        { "$ref": "semantic-event-v1.schema.json#/$defs/skillRoutedPayload" },
        { "$ref": "semantic-event-v1.schema.json#/$defs/workerAcceptedPayload" },
        { "$ref": "semantic-event-v1.schema.json#/$defs/workflowCompletedPayload" },
        { "$ref": "semantic-event-v1.schema.json#/$defs/workflowFailedPayload" }
      ]
    }
  }
}
