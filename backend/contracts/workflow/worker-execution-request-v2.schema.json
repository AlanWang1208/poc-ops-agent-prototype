{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/workflow/worker-execution-request-v2.schema.json",
  "title": "Worker execution request v2",
  "description": "执行 Worker 接收的短期、已授权且携带 Team Workspace 上下文的只读执行请求。",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "workspace", "executionRequestId", "authorizedAt", "expiresAt", "command"],
  "properties": {
    "contractVersion": { "const": "2.0" },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspaceId", "workspaceCode", "displayName"],
      "properties": {
        "workspaceId": { "type": "string", "minLength": 1 },
        "workspaceCode": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 }
      }
    },
    "executionRequestId": { "type": "string", "format": "uuid" },
    "authorizedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "command": { "$ref": "read-only-command-v2.schema.json" }
  }
}
