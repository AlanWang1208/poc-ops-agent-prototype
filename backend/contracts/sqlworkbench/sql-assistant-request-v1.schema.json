{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/sqlworkbench/sql-assistant-request-v1.schema.json",
  "title": "SQL assistant request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "connectionId",
    "targetEnvironment",
    "schema",
    "assistantAction",
    "sql",
    "limits",
    "idempotencyKey"
  ],
  "properties": {
    "contractVersion": { "const": "1.0" },
    "connectionId": { "type": "string", "minLength": 1, "maxLength": 200 },
    "targetEnvironment": { "enum": ["development", "test"] },
    "schema": { "type": "string", "minLength": 1, "maxLength": 128 },
    "assistantAction": {
      "enum": [
        "EXPLAIN_SQL",
        "OPTIMIZE_SQL",
        "ANALYZE_ERROR",
        "GENERATE_SELECT",
        "COMPARE_SUMMARY"
      ]
    },
    "sql": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxRows", "maxBytes", "timeoutSeconds"],
      "properties": {
        "maxRows": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "maxBytes": { "type": "integer", "minimum": 1, "maximum": 100000000 },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 300 }
      }
    },
    "diagnosticContext": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 200 }
  }
}
