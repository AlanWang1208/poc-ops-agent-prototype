{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/sqlworkbench/sql-query-request-v1.schema.json",
  "title": "SQL query request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "connectionId", "targetEnvironment", "schema", "action", "sql", "parameters", "limits", "idempotencyKey"],
  "properties": {
    "contractVersion": { "const": "1.0" },
    "connectionId": { "type": "string", "minLength": 1 },
    "targetEnvironment": { "enum": ["development", "test"] },
    "schema": { "type": "string", "minLength": 1 },
    "action": { "enum": ["VALIDATE", "EXPLAIN", "RUN_READ_ONLY", "PREFLIGHT_DML"] },
    "sql": { "type": "string", "minLength": 1, "maxLength": 100000 },
    "parameters": { "type": "array", "items": { "type": "object" } },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxRows", "maxBytes", "timeoutSeconds"],
      "properties": {
        "maxRows": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "maxBytes": { "type": "integer", "minimum": 1, "maximum": 100000000 },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 300 }
      }
    },
    "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 200 }
  }
}
