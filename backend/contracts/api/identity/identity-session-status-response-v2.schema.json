{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/api/identity/identity-session-status-response-v2.schema.json",
  "title": "Identity session status response v2",
  "description": "携带 Team Workspace 列表和当前工作空间角色的浏览器会话查询响应。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authenticated",
    "roles",
    "workspaces",
    "authenticationType",
    "passwordChangeRequired"
  ],
  "properties": {
    "authenticated": { "type": "boolean" },
    "subject": { "type": ["string", "null"], "minLength": 1 },
    "username": { "type": ["string", "null"], "minLength": 1 },
    "roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "workspaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["workspaceId", "workspaceCode", "displayName", "roles"],
        "properties": {
          "workspaceId": { "type": "string", "minLength": 1 },
          "workspaceCode": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "roles": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "currentWorkspaceId": { "type": ["string", "null"], "minLength": 1 },
    "authenticationType": { "type": "string", "minLength": 1 },
    "sessionExpiresAt": { "type": ["string", "null"], "format": "date-time" },
    "passwordChangeRequired": { "type": "boolean" }
  }
}
