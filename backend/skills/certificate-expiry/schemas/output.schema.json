{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/skills/certificate-expiry-read/1.0.0/output.schema.json",
  "title": "certificate-expiry-read 输出",
  "description": "证书有效期检查的结构化输出。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "endpoint",
    "subject",
    "issuer",
    "notAfter",
    "daysRemaining",
    "status"
  ],
  "properties": {
    "endpoint": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "issuer": {
      "type": "string",
      "minLength": 1
    },
    "notAfter": {
      "type": "string",
      "format": "date-time"
    },
    "daysRemaining": {
      "type": "integer"
    },
    "status": {
      "type": "string",
      "enum": [
        "VALID",
        "EXPIRING_SOON",
        "EXPIRED",
        "UNKNOWN"
      ]
    }
  }
}
